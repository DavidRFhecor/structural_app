# --- CONFIGURACIÓN DE APP ---
APP_NAME="FHECOR Structural Hub"
DEBUG=True
API_URL="http://localhost:8000"

# --- MOTOR MATEMÁTICO ---
# Versión del motor de Git que se debe auditar
ENGINE_VERSION="2026.03.RC1"
# Token para acceder al repo privado de fórmulas (si aplica)
GITHUB_PRIVATE_TOKEN="ghp_xxxxxxxxxxxx"

# --- EXPORTACIÓN ---
# Ruta donde se guardarán temporalmente los PDF generados
REPORT_STORAGE_DIR="./storage/reports"
# Firma que aparecerá en el pie de página de las memorias de cálculo
ENGINEERING_FIRM="FHECOR Ingenieros Consultores"